import tkinter
import tkinter as tk
from tkinter import ttk
from tkinter import messagebox

class Services:
    def __init__(self,name,master,schedule):
        self.name=name
        self.master=master
        self.schedule=schedule

    def show_available_hours(self):
        available_hours = []
        for hour, available in self.schedule.items():
            if available:
                available_hours.append(hour)
        return available_hours

def open_hair_window():
    for widget in window.winfo_children():
        widget.destroy()

    hair_label = tkinter.Label(window, text="Select Your Hair Service, Master and Preferable Time ")
    hair_label.grid(row=0, column=0, padx=10,pady=10)

    service_type_label = tkinter.Label(window, text="Choose Service Type:")
    service_type_label.grid(row=1,column=0,padx=10,pady=10)

    service_options = ["Hair Cut", "Hair Color", "Hair Styling"]
    service_type_combo = ttk.Combobox(window, values=service_options)
    service_type_combo.grid(row=1,column=1,padx=10,pady=10)
    service_type_combo.current(0)

    master_label = tk.Label(window, text="Choose Master:")
    master_label.grid(row=2,column=0,padx=10,pady=10)

    hair_service = Services(
        "Hair",
    ["Master Mia","Master Ana"],
    {
        "09:00 AM":True,
        "10:00 AM": True,
        "11:00 AM": True,
        "12:00 PM": True,
        "02:00 PM": True,
        "03:00 PM": True,
        "04:00 PM": True,
        "05:00 PM": True,
    })

    available_hours=hair_service.show_available_hours()

    hour_label = tk.Label(window, text="Choose Time:")
    hour_label.grid(row=3, column=0, padx=10, pady=10)

    hours_combo = ttk.Combobox(window, values=available_hours)
    hours_combo.grid(row=3, column=1, padx=10, pady=10)
    hours_combo.current(0)

    masters_combo = ttk.Combobox(window, values=hair_service.master)
    masters_combo.grid(row=2,column=1,padx=10,pady=10)
    masters_combo.current(0)

    #name
    name_label = tkinter.Label(window, text="Your Name:")
    name_label.grid(row=4, column=0)
    name_entry = tkinter.Entry(window)
    name_entry.grid(row=4, column=1)

    #phone number
    phone_number_label = tkinter.Label(window, text="Your Phone Number:")
    phone_number_label.grid(row=5, column=0,padx=10,pady=10)
    phone_number_entry = tkinter.Entry(window)
    phone_number_entry.grid(row=5, column=1,padx=10,pady=10)

    def book_and_save():
        name = name_entry.get()
        phone_number = phone_number_entry.get()
        master = masters_combo.get()
        time = hours_combo.get()
        service_type = service_type_combo.get()

        if time and master and phone_number:
            messagebox.showinfo(
                "Appointment Booked","Your "+service_type+" appointment with "+master+" at "+time+" has been booked."
            )

        #save data
            with open('Beauty_Bar.txt', 'a') as file_write:
                file_write.write(
                    name.title() + '-\t' + phone_number + '\t' + master + ',' + time + ',' + service_type + '\n')
                print('Saved')

        else:
            messagebox.showerror("Booking Error", "Please select a valid time and master abd make sure you entered your name and phone number.")

    #book appointment button
    book_button = tk.Button(window, text="Book Appointment",command=book_and_save)
    book_button.grid(row=6,column=0,columnspan=2,padx=10,pady=10)

def select_service(service):
    if service == "Hair Services":
        open_hair_window()
    else:
        messagebox.showinfo("Service Selected", "You have selected "+service+". Please proceed to schedule your appointment.")

window=tkinter.Tk()
window.title('Beauty Bar')
window.geometry("600x400")


frame=tkinter.Frame(window)
frame.pack()

empty_label=tkinter.Label(frame,text=" ")
empty_label.grid(row=0,column=0)

hair_button=tkinter.Button(frame, text='Hair Services',width=20,height=2,command=lambda:select_service("Hair Services") )
hair_button.grid(row=1,column=0)

nails_button=tkinter.Button(frame, text='Nail Services',width=20,height=2,command=lambda:select_service("Nail Services") )
nails_button.grid(row=2,column=0)

makeup_button=tkinter.Button(frame, text='Makeup Services',width=20,height=2,command=lambda:select_service("Makeup Services") )
makeup_button.grid(row=3,column=0)


window.mainloop()
